      {
        "run_command": "particle minecraft:portal ~ ~0.5 ~"
      },
      {
        "run_command": "playsound random.levelup @s"
      }
    ]
  },

  "lucky:reward_explosion": {
    "sequence": [
      {
        "randomize": [
          {
            "weight": 1,
            "run_command": "give @s tnt 5"
          },
          {
            "weight": 1,
            "run_command": "summon tnt ~ ~ ~"
          }
        ]
      },
      {
        "run_command": "particle minecraft:explosion ~ ~0.5 ~"
      },
      {
        "run_command": "playsound random.explode @s"
      }
    ]
